{
  "name": "@geonovum/standards-checker",
  "version": "1.0.8",
  "type": "module",
  "license": "EUPL-1.2",
  "description": "Standards checker engine with Spectral-based validation, CLI and API support",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./spectral/core": {
      "types": "./dist/spectral/core.d.ts",
      "import": "./dist/spectral/core.js"
    },
    "./spectral/functions": {
      "types": "./dist/spectral/functions.d.ts",
      "import": "./dist/spectral/functions.js"
    },
    "./spectral/parsers": {
      "types": "./dist/spectral/parsers.d.ts",
      "import": "./dist/spectral/parsers.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && tsdown",
    "dev": "tsdown --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@stoplight/better-ajv-errors": "^1.0.3",
    "@stoplight/json-ref-readers": "^1.2.2",
    "@stoplight/path": "^2.0.1",
    "@stoplight/spectral-core": "^1.22.0",
    "@stoplight/spectral-formats": "^1.8.2",
    "@stoplight/spectral-functions": "^1.10.2",
    "@stoplight/spectral-parsers": "^1.0.5",
    "@stoplight/spectral-ref-resolver": "^1.0.5",
    "@stoplight/types": "^14.1.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "json-schema-merge-allof": "^0.8.1",
    "nimma": "^0.7.2",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@types/json-schema-merge-allof": "^0.6.5",
    "@types/node": "^25.6.0",
    "@types/ramda": "^0.31.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
