    "@stoplight/spectral-core": "^1.21.0",
    "@stoplight/spectral-parsers": "^1.0.5",
    "@stoplight/types": "^14.1.1",
    "@uiw/react-codemirror": "^4.25.7",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11",
