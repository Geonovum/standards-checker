{
  "name": "@geonovum/standards-checker",
  "version": "1.2.0-beta.2",
  "type": "module",
  "license": "EUPL-1.2",
  "description": "Standards checker engine with Spectral-based validation, React UI, CLI toolkit and shared Vite/ESLint/Prettier/TS configs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geonovum/standards-checker"
  },
  "engines": {
    "node": ">=20.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "client.d.ts",
    "vitest.d.ts",
    "eslint.config.js",
    "prettier.config.js",
    "tsconfig.app.json",
    "tsconfig.node.json"
  ],
  "bin": {
    "build-cli": "./bin/build-cli.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js"
    },
    "./vitest-matchers": {
      "types": "./dist/vitest-matchers.d.ts",
      "import": "./dist/vitest-matchers.js"
    },
    "./spectral/*": {
      "types": "./dist/spectral/*.d.ts",
      "import": "./dist/spectral/*.js"
    },
    "./client": "./client.d.ts",
    "./vitest-client": "./vitest.d.ts",
    "./index.css": "./dist/index.css",
    "./eslint.config": "./eslint.config.js",
    "./prettier": "./prettier.config.js",
    "./tsconfig.app.json": "./tsconfig.app.json",
    "./tsconfig.node.json": "./tsconfig.node.json"
  },
  "scripts": {
    "build": "tsc --noEmit && tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "esbuild": "^0.28.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.7",
    "@eslint/js": "^10.0.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@stoplight/better-ajv-errors": "^1.0.3",
    "@stoplight/json-ref-readers": "^1.2.2",
    "@stoplight/path": "^2.0.1",
    "@stoplight/spectral-core": "^1.23.1",
    "@stoplight/spectral-formats": "^1.8.5",
    "@stoplight/spectral-functions": "^1.10.5",
    "@stoplight/spectral-parsers": "^1.0.5",
    "@stoplight/spectral-ref-resolver": "^1.0.5",
    "@stoplight/spectral-rulesets": "^1.22.6",
    "@stoplight/types": "^14.1.1",
    "@uiw/react-codemirror": "^4.25.11",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "esbuild": "^0.28.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "js-yaml": "^4.3.0",
    "json-schema-merge-allof": "^0.8.1",
    "lucide-react": "^1.24.0",
    "nimma": "^0.7.2",
    "prettier": "^3.9.5",
    "ramda": "^0.32.0",
    "tsdown": "^0.21.10",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/cli": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema-merge-allof": "^0.6.5",
    "@types/node": "^25.9.5",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "overrides": {
    "@asyncapi/specs": "6.11.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@asyncapi/specs": "6.11.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": ">=10"
      }
    }
  }
}
